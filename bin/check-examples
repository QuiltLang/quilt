#!/usr/bin/env bash
# Exercise the bundled examples/ so they can't silently rot as the grammar and
# expander evolve. Two gates, both run via the same `quilt` CLI a user would:
#
#   1. `quilt check` every examples/**/*.quilt — parse + expand, nothing written.
#   2. For any example with a *committed, generated* expected output (e.g.
#      examples/countdown.rs next to examples/countdown.rs.quilt), `quilt expand`
#      it and diff against the committed file, so output drift is caught too.
#
# The diff ignores the first line of generated files — the
# `//! DO NOT EDIT. GENERATED BY `quilt expand <path>`` header echoes however
# expand happened to be invoked (absolute vs. relative path, cwd), so it is not
# reproducible across machines. Only the generated *body* is compared.
#
# Files without that header (e.g. the hand-written cargo-demo/src/main.rs) are
# check-only: they are still parsed/expanded by gate 1 but not diffed.
#
# NOT covered here: actually *running* the .py.quilt runtime examples, which
# needs the maturin-built quilt_python module — the `python` CI job does that.
#
# For CI and pre-commit. Run from anywhere once the direnv env is active.
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# Portable array fill (macOS still ships bash 3.2, which lacks `mapfile`).
quilts=()
while IFS= read -r f; do
  quilts+=("$f")
done < <(find examples -name '*.quilt' | sort)
if [ "${#quilts[@]}" -eq 0 ]; then
  echo "error: no examples/*.quilt files found under $ROOT/examples" >&2
  exit 1
fi

echo "==> quilt check (${#quilts[@]} files)"
"$ROOT/bin/quilt" check "${quilts[@]}"

# Gate 2: re-expand and diff against any committed, generated output.
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT
header_re='^//! DO NOT EDIT\. GENERATED BY '
drift=0
compared=0
for q in "${quilts[@]}"; do
  out="${q%.quilt}"                              # examples/countdown.rs.quilt -> examples/countdown.rs
  [ -f "$out" ] || continue                      # no committed output -> check-only
  IFS= read -r first <"$out" || true
  [[ "$first" =~ $header_re ]] || continue        # not a generated file -> check-only
  compared=$((compared + 1))

  # Expand a copy in a scratch dir so the working tree's committed output is
  # never clobbered (`quilt expand foo.quilt` writes the sibling `foo`).
  work="$tmp/$(basename "$out")"
  cp "$q" "$work.quilt"
  "$ROOT/bin/quilt" expand "$work.quilt" >/dev/null

  # Compare bodies, dropping the non-reproducible header line from each.
  if ! diff -u <(tail -n +2 "$out") <(tail -n +2 "$work"); then
    echo "error: $out is stale — re-run 'quilt expand $q' and commit it" >&2
    drift=1
  fi
done

echo "==> expand diff: compared $compared committed output(s) against fresh expansion"
if [ "$drift" -ne 0 ]; then
  echo "examples FAILED: committed output drifted from current expander" >&2
  exit 1
fi
echo "examples OK ✓"
