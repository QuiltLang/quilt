{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "quilt",
      "camelcase": "Quilt",
      "title": "Quilt",
      "scope": "source.quilt",
      "file-types": [
        "quilt"
      ],
      "injection-regex": "^quilt$",
      "class-name": "TreeSitterQuilt"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT OR Apache-2.0",
    "description": "Quilt grammar for tree-sitter",
    "authors": [
      {
        "name": "Alexander Varga",
        "email": "varga.alex@gmail.com",
        "url": "https://asvarga.github.io/"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-quilt"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}