#!/usr/bin/env quilt
from quilt import *

# A quoted Python expression expands to builder code that rebuilds the term;
# coparse() serializes a term back to source.
expr = py‚ÜĖ1 + 2‚Üó
print("expr   =", expr.coparse())

# An unquote splices an existing term into a quote.
ten = py‚ÜĖ10‚Üó
scaled = py‚ÜĖ‚Üôten‚Üė * 100‚Üó
print("scaled =", scaled.coparse())
