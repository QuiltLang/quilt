    // See https://go.microsoft.com/fwlink/?LinkId=827846 to learn about workspace recommendations.
    "recommendations": [
        // Rust development, and the downstream server quilt-lsp drives for
        // .rs.quilt files.
        "rust-lang.rust-analyzer",

        // Provides the source.wgsl TextMate grammar that the Quilt extension's
        // wgsl↖…↗ embedded regions include, plus the wgsl-analyzer server
