        "wgsl-analyzer.wgsl-analyzer",

        // Python development for .py.quilt files (the quilt_python bindings and
        // pyright as the downstream server).
        "ms-python.python",

        // Cargo.toml editing.
        "tamasfe.even-better-toml"
    ]
}
